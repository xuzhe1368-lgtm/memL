MEML_HOST=127.0.0.1
MEML_PORT=8000
MEML_LOG_LEVEL=INFO
MEML_DATA_DIR=/opt/memL/data/chromadb
MEML_TENANTS_FILE=/opt/memL/tenants.yaml
MEML_ADMIN_TOKEN=REPLACE_WITH_STRONG_ADMIN_TOKEN
MEML_DEDUP_ENABLED=true
MEML_DEDUP_THRESHOLD=0.92
MEML_HYBRID_ALPHA=0.7
MEML_QUEUE_FILE=/opt/memL/data/pending_writes.jsonl
MEML_IDEMP_FILE=/opt/memL/data/idempotency.json
MEML_IDEMP_TTL_SEC=604800
MEML_IDEMP_MAX_ENTRIES=20000
MEML_TENANT_MAX_MEMORIES=50000
MEML_TENANT_WRITE_RATE_PER_MIN=120
MEML_AUDIT_LOG_FILE=/opt/memL/data/audit.log
MEML_IMPORTANCE_LONGTERM_THRESHOLD=0.75
MEML_EMBED_API_URL=https://api.siliconflow.cn/v1/embeddings
MEML_EMBED_API_KEY=REPLACE_ME
MEML_EMBED_MODEL=BAAI/bge-large-zh-v1.5
MEML_EMBED_TIMEOUT_SEC=8
MEML_EMBED_MAX_RETRIES=2
MEML_EMBED_MAX_CONCURRENCY=16
